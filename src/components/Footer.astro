---
const today = new Date();
---

<section id="contact" class="relative py-20 bg-gradient-to-br from-slate-900 via-gray-900 to-black overflow-hidden">
    <!-- Background decorative elements -->
    <div class="absolute inset-0 opacity-10">
        <div class="absolute top-20 left-10 w-32 h-32 bg-amber-300 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute bottom-20 right-10 w-40 h-40 bg-orange-300 rounded-full blur-3xl animate-pulse delay-1000"></div>
    </div>

    <div class="relative z-10 container mx-auto px-8">
        <div class="text-center mb-16">
            <h2 class="text-5xl font-bold bg-gradient-to-r from-amber-400 via-orange-400 to-red-400 bg-clip-text text-transparent mb-6">
                Reserva Ahora
            </h2>
            <div class="w-24 h-1 bg-gradient-to-r from-amber-400 to-orange-500 rounded-full mx-auto mb-8"></div>
            <p class="text-xl text-gray-300 max-w-2xl mx-auto leading-relaxed">
                Contáctanos para hacer de tu evento algo inolvidable
            </p>
        </div>

        <div class="grid lg:grid-cols-2 gap-16 items-start">
            <!-- Contact Info -->
            <div class="space-y-8">
                <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
                    <h3 class="text-2xl font-semibold text-white mb-6">Información de Contacto</h3>
                    <div class="space-y-4">
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-amber-500/20 rounded-full flex items-center justify-center">
                                <span class="text-amber-400 text-xl">📞</span>
                            </div>
                            <div>
                                <p class="text-gray-300">Teléfono</p>
                                <p class="text-white font-semibold">+34 123 456 789</p>
                            </div>
                        </div>
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-amber-500/20 rounded-full flex items-center justify-center">
                                <span class="text-amber-400 text-xl">✉️</span>
                            </div>
                            <div>
                                <p class="text-gray-300">Email</p>
                                <p class="text-white font-semibold">info@loscamaradastrio.com</p>
                            </div>
                        </div>
                        <div class="flex items-center space-x-4">
                            <div class="w-12 h-12 bg-amber-500/20 rounded-full flex items-center justify-center">
                                <span class="text-amber-400 text-xl">📍</span>
                            </div>
                            <div>
                                <p class="text-gray-300">Ubicación</p>
                                <p class="text-white font-semibold">Elda y Alicante</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Form -->
            <div class="bg-white/5 backdrop-blur-sm rounded-2xl p-8 border border-white/10">
                <h3 class="text-2xl font-semibold text-white mb-6">Solicita tu Presupuesto</h3>
                <form class="space-y-6">
                    <div class="grid grid-cols-2 gap-4">
                        <input
                            type="text"
                            placeholder="Nombre"
                            class="bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:border-amber-400 transition-colors"
                        />
                        <input
                            type="email"
                            placeholder="Email"
                            class="bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:border-amber-400 transition-colors"
                        />
                    </div>
                    <input
                        type="tel"
                        placeholder="Teléfono"
                        class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:border-amber-400 transition-colors"
                    />
                    <select class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white focus:outline-none focus:border-amber-400 transition-colors">
                        <option value="">Tipo de evento</option>
                        <option value="boda">Boda</option>
                        <option value="corporativo">Evento Corporativo</option>
                        <option value="privado">Fiesta Privada</option>
                        <option value="concierto">Concierto Privado</option>
                    </select>
                    <textarea
                        rows="4"
                        placeholder="Cuéntanos sobre tu evento..."
                        class="w-full bg-white/10 border border-white/20 rounded-lg px-4 py-3 text-white placeholder-gray-400 focus:outline-none focus:border-amber-400 transition-colors resize-none"
                    ></textarea>
                    <button
                        type="submit"
                        class="w-full bg-gradient-to-r from-amber-500 to-orange-600 text-white px-8 py-4 rounded-lg font-semibold text-lg hover:from-amber-600 hover:to-orange-700 transition-all duration-300 shadow-lg hover:shadow-xl transform hover:-translate-y-1"
                    >
                        Enviar Solicitud
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

<footer class="bg-black py-8">
    <div class="container mx-auto px-8 text-center">
        <p class="text-gray-400">&copy; {today.getFullYear()} Los Camaradas Trío. Todos los derechos reservados.</p>
    </div>
</footer>
