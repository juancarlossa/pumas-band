---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import Main from "@/components/main/Main.astro";
import { getAllTexts, getAllMedia, getAllCalendarEvents } from "@/lib/db";

// Cargar textos y medios desde la base de datos
const texts = await getAllTexts();
const textsMap = Object.fromEntries(texts.map((t) => [t.key, t.content]));

const media = await getAllMedia();
const mediaMap = Object.fromEntries(
	media.map((m) => [
		m.key,
		{ url: m.url, type: m.type, alt: m.alt_text || "" },
	]),
);

// Cargar eventos del calendario
const calendarEvents = await getAllCalendarEvents();
---

<!doctype html>
<html lang="en">
	<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	<body
		class="w-full overflow-x-hidden flex flex-col justify-center items-center"
	>
		<Header texts={textsMap} />
		<Main
			texts={textsMap}
			media={mediaMap}
			calendarEvents={calendarEvents}
		/>
		<Footer texts={textsMap} />
	</body>
</html>
