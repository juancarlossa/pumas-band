---
import { isAuthenticated } from "@/lib/auth";
import { getAllTexts, getAllMedia, getAllCalendarEvents } from "@/lib/db";
import BaseHead from "@/components/BaseHead.astro";
import { SITE_DESCRIPTION } from "@/consts";
import { HeaderEditable } from "@/components/HeaderEditable";
import { FooterEditable } from "@/components/FooterEditable";
import { HeroEditable } from "@/components/main/HeroEditable";
import { NosotrosEditable } from "@/components/main/NosotrosEditable";
import { CarouselEditable } from "@/components/juankui/CarouselEditable";
import { EventosEditable } from "@/components/juankui/EventosEditable";
import { ServicesEditable } from "@/components/main/ServicesEditable";
import { AdminCalendar } from "@/components/admin/AdminCalendar";

export const prerender = false;

const authenticated = await isAuthenticated(Astro.cookies);

if (!authenticated) {
    return Astro.redirect("/admin/login");
}

let textsMap: Record<string, string> = {};
let mediaMap: Record<string, { url: string; type: string; alt?: string }> = {};
let calendarEvents: any[] = [];

try {
    const allTexts = await getAllTexts();
    textsMap = Object.fromEntries(allTexts.map((t) => [t.key, t.content]));

    const allMedia = await getAllMedia();
    mediaMap = Object.fromEntries(
        allMedia.map((m) => [
            m.key,
            { url: m.url, type: m.type, alt: m.alt_text || "" },
        ]),
    );

    const events = await getAllCalendarEvents();
    calendarEvents = events.map((e) => ({
        id: e.id,
        date: new Date(e.event_date),
        isBusy: e.is_busy,
        titulo: e.titulo,
        descripcion: e.descripcion || "",
    }));
} catch (error) {
    console.error("Error loading texts/media/events:", error);
}
---

<!doctype html>
<html lang="es">
    <BaseHead title="Admin - Puma's Band" description={SITE_DESCRIPTION} />
    <body class="w-full flex flex-col justify-center items-center">
        <HeaderEditable client:load texts={textsMap} />

        <div class="fixed top-20 right-4 z-50 flex gap-2">
            <div
                class="bg-gradient-to-r from-indigo-600 to-purple-600 text-white px-4 py-2 rounded-lg shadow-lg font-semibold"
            >
                Modo Edición - Doble click para editar
            </div>
            <button
                id="logoutBtn"
                class="bg-red-500 hover:bg-red-600 text-white px-4 py-2 rounded-lg shadow-lg font-semibold transition-colors"
            >
                Cerrar Sesión
            </button>
        </div>

        <main
            class="w-full flex flex-col flex-1 justify-center items-center gap-8"
        >
            <section class="w-full">
                <HeroEditable
                    client:load
                    texts={textsMap}
                    media={mediaMap}
                    calendarEvents={calendarEvents}
                />
                <NosotrosEditable
                    client:load
                    texts={textsMap}
                    media={mediaMap}
                />
                <CarouselEditable
                    client:load
                    texts={textsMap}
                    media={mediaMap}
                />
                <EventosEditable
                    client:load
                    texts={textsMap}
                    media={mediaMap}
                />
                <ServicesEditable
                    client:load
                    texts={textsMap}
                    media={mediaMap}
                />
            </section>
        </main>

        <FooterEditable client:load texts={textsMap} />

        <script>
            const logoutBtn = document.getElementById("logoutBtn");

            if (logoutBtn) {
                logoutBtn.addEventListener("click", async () => {
                    try {
                        const response = await fetch("/api/auth/logout", {
                            method: "POST",
                        });

                        if (response.ok) {
                            window.location.href = "/admin/login";
                        }
                    } catch (error) {
                        console.error("Logout error:", error);
                    }
                });
            }
        </script>
    </body>
</html>
